# -------------------------------
# .htaccess - pass 프로젝트용 설정 (정리 버전)
# -------------------------------

# URL 재작성 엔진 켜기
RewriteEngine On

# -------------------------------------------------------------------
# 1. 실제 파일/디렉터리는 그대로 접근
# -------------------------------------------------------------------
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# -------------------------------------------------------------------
# 2. 그 외 모든 요청은 index.php로 전달
# -------------------------------------------------------------------
RewriteRule ^ index.php [L,QSA]
